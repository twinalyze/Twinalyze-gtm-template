___SANDBOXED_JS_FOR_WEB_TEMPLATE___

var log = require('logToConsole');
var copyFromWindow = require('copyFromWindow');
var setInWindow = require('setInWindow');
var callInWindow = require('callInWindow');
var injectScript = require('injectScript');
var templateStorage = require('templateStorage');

var SDK_URL = 'https://cdn.jsdelivr.net/npm/@twinalyze/web-analytics@1.0.19/dist/cdn.global.min.js';
var SDK_NAME = 'TwinalyzeAnalytics';

var INIT_FLAG = '__twinalyze_initialized__';
var STORAGE_KEY = 'twinalyze_instances';
var QUEUE_KEY = 'twinalyze_queue';

var PREFIX = '[Twinalyze / GTM] ';
var MAX_SDK_RETRIES = 2;
var MAX_QUEUE_SIZE = 50;

var sdkRetryCount = 0;

/* ---------------- utils ---------------- */

function normalize(v) {
  if (v === true || v === 'true') return true;
  if (v === false || v === 'false') return false;
  if (v === 'null') return null;
  if (v === 'undefined') return undefined;
  return v;
}

function valueOrDefault(v, fallback) {
  if (v === undefined || v === null || v === '') return fallback;
  return v;
}

function trimTrailingSlash(url) {
  if (!url) return url;

  if (url.charAt(url.length - 1) === '/') {
    return url.substring(0, url.length - 1);
  }

  return url;
}

function trimText(value) {
  var item = '' + value;

  while (item.length > 0 && item.charAt(0) === ' ') {
    item = item.substring(1);
  }

  while (item.length > 0 && item.charAt(item.length - 1) === ' ') {
    item = item.substring(0, item.length - 1);
  }

  return item;
}

function csvToArray(value, fallback) {
  var result = [];
  var parts;
  var i;
  var item;

  if (!value) return fallback;

  parts = ('' + value).split(',');

  for (i = 0; i < parts.length; i++) {
    item = trimText(parts[i]);

    if (item) {
      result.push(item);
    }
  }

  return result.length ? result : fallback;
}

function logInfo(msg) {
  if (normalize(data.debug) === true) {
    log(PREFIX + 'INFO: ' + msg);
  }
}

function logError(msg) {
  log(PREFIX + 'ERROR: ' + msg);
}

function success(msg) {
  logInfo(msg);
  data.gtmOnSuccess();
}

function fail(msg) {
  logError(msg);
  data.gtmOnFailure();
}

function getSdk() {
  return copyFromWindow(SDK_NAME);
}

/* ---------------- safe call ---------------- */

function safeCall(method, args) {
  var sdk;

  args = args || [];
  sdk = getSdk();

  if (!sdk || typeof sdk[method] !== 'function') {
    fail(method + ' not available');
    return false;
  }

  if (args.length === 0) {
    callInWindow(SDK_NAME + '.' + method);
  } else if (args.length === 1) {
    callInWindow(SDK_NAME + '.' + method, args[0]);
  } else if (args.length === 2) {
    callInWindow(SDK_NAME + '.' + method, args[0], args[1]);
  } else {
    fail('Too many arguments for ' + method);
    return false;
  }

  return true;
}

/* ---------------- storage helpers ---------------- */

function getStorageArray(key) {
  return templateStorage.getItem(key) || [];
}

function setStorageArray(key, arr) {
  templateStorage.setItem(key, arr);
}

/* ---------------- queue ---------------- */

function enqueue(eventObj) {
  var q = getStorageArray(QUEUE_KEY);

  if (q.length >= MAX_QUEUE_SIZE) {
    q.shift();
  }

  q.push(eventObj);
  setStorageArray(QUEUE_KEY, q);
}

function flushQueue() {
  var q = getStorageArray(QUEUE_KEY);
  var ev;

  if (!q.length) return;

  logInfo('Flushing queue: ' + q.length);

  while (q.length) {
    ev = q.shift();
    safeCall(ev.method, ev.args);
  }

  setStorageArray(QUEUE_KEY, q);
}

/* ---------------- init helpers ---------------- */

function isInitialized() {
  return copyFromWindow(INIT_FLAG) === true;
}

function markInitialized() {
  setInWindow(INIT_FLAG, true, true);
}

function getInstanceKey() {
  return [
    data.apiKey || '',
    data.apiBaseUrl || '',
    data.sdkUrl || SDK_URL
  ].join('|');
}

/* ---------------- enhanced measurement ---------------- */

function buildEnhancedMeasurement() {
  var enableSiteSearch = normalize(data.enableSiteSearch) !== false;
  var enableFileDownloads = normalize(data.enableFileDownloads) !== false;

  return {
    pageViews: normalize(data.enablePageViews) !== false,

    scrolls: normalize(data.enableScrollTracking) !== false,

    outboundClicks: normalize(data.enableAutoClickTracking) !== false,

    formInteractions: normalize(data.enableFormInteractions) !== false,

    siteSearch: enableSiteSearch
      ? {
          params: csvToArray(
            data.siteSearchParams,
            ['q', 's', 'search', 'query']
          )
        }
      : false,

    fileDownloads: enableFileDownloads
      ? {
          extensions: csvToArray(
            data.fileDownloadExtensions,
            [
              'pdf',
              'zip',
              'apk',
              'doc',
              'docx',
              'xls',
              'xlsx',
              'ppt',
              'pptx'
            ]
          )
        }
      : false
  };
}

/* ---------------- custom event properties ---------------- */

function buildEventProperties() {
  var props = {};
  var rows = data.eventPropertyRows || [];
  var i;
  var row;

  for (i = 0; i < rows.length; i++) {
    row = rows[i];

    if (row && row.propertyName) {
      props[row.propertyName] = normalize(row.propertyValue);
    }
  }

  return props;
}

/* ---------------- main logic ---------------- */

function runTag() {
  var type = data.tagType;
  var instances;
  var instanceKey;
  var payload;
  var ok;
  var args;

  if (!type) return fail('tagType required');

  logInfo('Running: ' + type);

  /* ---------- INIT SDK ---------- */

  if (type === 'init') {
    if (!data.apiKey) return fail('apiKey required');
    if (!data.secretKey) return fail('secretKey required');

    payload = {
      apiKey: data.apiKey,
      secretKey: data.secretKey,

      version: valueOrDefault(data.sdkVersion, '1.0.19'),

      apiBaseUrl: trimTrailingSlash(
        valueOrDefault(
          data.apiBaseUrl,
          'https://api.twinalyze.com'
        )
      ),

      debug: normalize(data.debug) === true,

     source: 'web',

      enhancedMeasurement: buildEnhancedMeasurement()
    };

    instances = getStorageArray(STORAGE_KEY);
    instanceKey = getInstanceKey();

    if (isInitialized() || instances.indexOf(instanceKey) !== -1) {
      logInfo('Init already done');
      flushQueue();
      return success('Init skipped');
    }

    ok = safeCall('init', [payload]);

    if (ok) {
      instances.push(instanceKey);
      setStorageArray(STORAGE_KEY, instances);
      markInitialized();
      flushQueue();
      return success('Init success');
    }

    return fail('Init failed');
  }

  /* ---------- TRACK CUSTOM EVENT ---------- */

  if (type === 'track') {
    if (!data.eventName) return fail('eventName required');

    args = [
      data.eventName,
      buildEventProperties()
    ];

    if (!isInitialized()) {
      logInfo('Queueing event because init is not ready');

      enqueue({
        method: 'track',
        args: args
      });

      return success('Queued');
    }

    ok = safeCall('track', args);

    if (ok) return success('Tracked: ' + data.eventName);
    return fail('Track failed');
  }

  return fail('Unsupported type: ' + type);
}

/* ---------------- SDK loader ---------------- */

function ensureSdkLoaded(callback) {
  var url = data.sdkUrl || SDK_URL;

  if (getSdk()) {
    return callback();
  }

  injectScript(
    url,
    function() {
      if (!getSdk()) {
        return fail('SDK loaded but unavailable');
      }

      callback();
    },
    function() {
      sdkRetryCount = sdkRetryCount + 1;

      if (sdkRetryCount <= MAX_SDK_RETRIES) {
        logInfo('Retry SDK load: ' + sdkRetryCount);
        ensureSdkLoaded(callback);
      } else {
        fail('SDK failed to load');
      }
    },
    url
  );
}

/* ---------------- start ---------------- */

ensureSdkLoaded(runTag);


